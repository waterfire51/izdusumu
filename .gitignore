# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (secrets; commit .env.example instead)
.env
.env.*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma — https://www.prisma.io/docs/guides/migrate/developing-with-prisma-migrate
# Migration klasörünü genelde repoya ekleyin; yerel SQLite / dump dosyalarını hariç tutun
/prisma/*.db
/prisma/*.db-journal
/prisma/*.sqlite
/prisma/*.sqlite3
*.db
*.db-journal

# prisma generate çıktısı (özel output path kullanırsanız)
node_modules/.prisma/

# veritabanı yedekleri / export
*.sql.gz
dump.rdb

# IDE / editor
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo

# turbo / monorepo (ileride gerekirse)
.turbo
